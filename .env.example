# Database
DATABASE_URL=sqlite:data/monitoring.db

# Server
PORT=8080
APP_NAME="Basic Monitoring"

# Telegram Bot
TELEGRAM_GLOBAL_BOT_TOKEN=your_telegram_bot_token

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
FROM_NAME="Basic Monitoring"
SMTP_ENCRYPTION=tls
